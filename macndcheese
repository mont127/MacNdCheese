#!/usr/bin/env python3
"""macndcheese CLI -- an interactive terminal client for the MacNdCheese backend.

MacNdCheese is a SwiftUI app talkin to backend_server.py over a line-JSON protocol:
one  {"id": N, "cmd": name, ..params}  per line goes IN, one
     {"id": N, "ok": true, "data": ..}  (or {"ok": false, "error": ..})  per line comes OUT.

run it with NO args + you get an interactive shell (a REPL) that keeps ONE backend alive
the hole session -- so state sticks around: launch steam, then `status` sees it, `bottles
kill` stops it, + you `use` a bottle once insted of retypin its long path. run it WITH a
subcommand + it does that one thing + exits (handy for scriptin).

  ./macndcheese                          # interactive shell
  ./macndcheese bottles list             # one-shot
  ./macndcheese launch "Half-Life"       # launch by name, returns right away
  ./macndcheese launch "Half-Life" --logs  # ..and stream its log until control-c
  ./macndcheese raw scan_games prefix=/path/to/Bottle
"""
from __future__ import annotations
import argparse
import atexit
import itertools
import json
import os
import re
import shlex
import subprocess
import sys
import time

HERE = os.path.dirname(os.path.realpath(__file__))  # realpath, not abspath -- follows the mnc symlink
BACKEND = os.path.join(HERE, "backend_server.py")
HISTFILE = os.path.expanduser("~/.mnc_history")
GENERAL_LOG_PATH = os.path.expanduser("~/Library/Logs/MacNCheese/macncheese.log")
PATH_BIN_DIR = "/usr/local/bin"

# ---- tiny ansi paint (only when we're a real terminal) --------------------------
_TTY = sys.stdout.isatty()
_BOLD, _DIM, _RED, _GRN, _YEL, _CYN = "1", "2", "31", "32", "33", "36"


def _paint(text: str, code: str) -> str:
    return f"\033[{code}m{text}\033[0m" if _TTY else text


# ---- the backend pipe -----------------------------------------------------------
class BackendError(RuntimeError):
    """raised when the backend anwsers ok=false."""


class Backend:
    """spawns backend_server.py once + does request/reply, allways matchin our OWN id
    back out of the stream (scan_games/scan_apps run on a worker so there replys can
    land out of order -- we cant just take the next line)."""

    def __init__(self, verbose: bool = False) -> None:
        if not os.path.exists(BACKEND):
            sys.exit(f"cant find backend_server.py next to the cli (looked in {HERE})")
        self._nextid = itertools.count(1)
        errto = None if verbose else subprocess.DEVNULL  # backend logs -> stderr, hide em
        self._proc = subprocess.Popen(
            [sys.executable, BACKEND],
            stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=errto,
            text=True, bufsize=1, cwd=HERE,
        )

    def call(self, cmd: str, params: "dict | None" = None):
        if self._proc.poll() is not None:
            raise BackendError("the backend has died -- restart the shell")
        rid = next(self._nextid)
        req = {"id": rid, "cmd": cmd}
        if params:
            req.update(params)
        assert self._proc.stdin and self._proc.stdout
        self._proc.stdin.write(json.dumps(req) + "\n")
        self._proc.stdin.flush()
        while True:
            raw = self._proc.stdout.readline()
            if not raw:
                raise BackendError("backend closed the pipe befor replyin (it may of crashd -- try --verbose)")
            raw = raw.strip()
            if not raw:
                continue
            try:
                resp = json.loads(raw)
            except json.JSONDecodeError:
                continue  # not our json -- skip
            if resp.get("id") != rid:
                continue  # a diffrent commands reply -- keep readin
            if resp.get("ok"):
                return resp.get("data")
            raise BackendError(resp.get("error") or "unknown backend error")

    def close(self) -> None:
        try:
            if self._proc.stdin:
                self._proc.stdin.close()   # eof lets the backend main loop end cleanly
            self._proc.wait(timeout=5)
        except Exception:
            self._proc.kill()


# ---- shell state (persists accross commands in the REPL) ------------------------
class State:
    def __init__(self) -> None:
        self.prefix: "str | None" = None   # the currently-selected bottle path
        self.name: "str | None" = None     # ..and its name (for the prompt)
        self.bottles: list = []            # last-fetched bottle list, so `use N` works
        # pids from a launch_game/legendary_launch_game call this run made. the
        # backend clears discord presence, releases game mode, and reverts
        # per-launch dll patches from daemon threads that watch these pids and
        # only run once the process exits -- but those threads die the instant
        # the backend itself is torn down. a one-shot cli command would normally
        # do that right after `launch` returns, well before a real game exits,
        # so main() keeps the backend alive (detached, not blocking the shell)
        # until every pid here is gone. see _detach_and_wait.
        self.keep_alive_pids: set = set()


# ---- generic helpers --------------------------------------------------------------------
def _known_cmds() -> "list[str]":
    """scrape the cmd_* names outa backend_server.py so the list cant drift."""
    try:
        with open(BACKEND, encoding="utf-8", errors="ignore") as fh:
            src = fh.read()
    except OSError:
        return []
    return sorted(set(re.findall(r"^def cmd_([a-z0-9_]+)", src, re.M)))


def _emit(data, as_json: bool) -> None:
    if as_json:
        print(json.dumps(data, indent=2, default=str))
    elif data is None:
        print(_paint("ok", _GRN))
    elif isinstance(data, (dict, list)):
        print(json.dumps(data, indent=2, default=str))
    else:
        print(data)


def _parse_kv(pairs: "list[str]") -> dict:
    """key=value tokens -> params. values get json-parsed when they can (true/200/[..]),
    otherwise kept as a plain string."""
    out: dict = {}
    for tok in pairs:
        if "=" not in tok:
            raise BackendError(f"bad param {tok!r} -- expektd key=value")
        key, val = tok.split("=", 1)
        try:
            out[key] = json.loads(val)
        except json.JSONDecodeError:
            out[key] = val
    return out


def _print_kv(pairs) -> None:
    """pairs: an iterable of (label, value). left-aligned two-column block, no deps."""
    pairs = list(pairs)
    if not pairs:
        print(_paint("Nothing to show.", _DIM))
        return
    width = max(len(str(k)) for k, _ in pairs)
    for k, v in pairs:
        print(f"  {str(k).ljust(width)}  {v}")


def _print_table(headers, rows) -> None:
    """rows: an iterable of tuples, same length as headers. plain columns, no deps."""
    rows = list(rows)
    if not rows:
        print(_paint("Nothing to show.", _DIM))
        return
    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(str(cell)))

    def fmt(row):
        return "  ".join(str(c).ljust(w) for c, w in zip(row, widths))

    print(_paint(fmt(headers), _BOLD))
    for row in rows:
        print(fmt(row))


def _pid_alive(pid) -> bool:
    if not pid:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except Exception:
        return True


def _detach_and_wait(backend: "Backend", pids: set) -> None:
    """Give the shell back immediately, but keep the backend process running
    in the background until every launched pid has exited -- otherwise its
    own cleanup threads (discord presence, game mode, dll-patch revert) get
    killed mid-wait the moment this cli command exits. Forks so the terminal
    isn't blocked; the child fully detaches, then just closes the backend's
    input once there's nothing left to wait for, letting it shut down (and
    finish that cleanup) on its own."""
    try:
        child_pid = os.fork()
    except OSError:
        backend.close()  # can't fork -- closing now is better than leaking the process
        return
    if child_pid > 0:
        return  # parent: hand the terminal straight back

    # child: detach fully so it isn't tied to the terminal or shell job control.
    try:
        os.setsid()
    except OSError:
        pass
    try:
        while any(_pid_alive(pid) for pid in pids):
            time.sleep(1.0)
        time.sleep(2.0)  # let the backend's own watcher threads notice and finish
        if backend._proc.stdin:
            backend._proc.stdin.close()  # eof -- the backend shuts itself down cleanly
    except Exception:
        pass
    os._exit(0)


def _tail_log(path: str, pid) -> None:
    """poll-tail a log file until control-c or the process exits. no external `tail`,
    just a plain readline loop -- keeps this stdlib-only and identical on any macOS python."""
    deadline = time.time() + 3.0
    while not os.path.exists(path) and time.time() < deadline:
        time.sleep(0.1)
    if not os.path.exists(path):
        print(f"Log file never appeared ({path}) -- it may have failed to start.")
        return
    print(_paint(f"Streaming {path} -- control-c to detach (it keeps running):", _DIM))
    try:
        with open(path, "r", errors="ignore") as f:
            f.seek(0, os.SEEK_END)
            last_check = time.time()
            while True:
                line = f.readline()
                if line:
                    print(line, end="")
                    continue
                if pid and time.time() - last_check > 1.0:
                    last_check = time.time()
                    if not _pid_alive(pid):
                        for rest in f:
                            print(rest, end="")
                        print(_paint("[exited]", _DIM))
                        return
                time.sleep(0.2)
    except KeyboardInterrupt:
        print()
        print(f"Detached -- it keeps running (PID {pid}).")


# ---- bottle + game resolution -----------------------------------------------------
def _all_bottles(backend: "Backend", state: State) -> list:
    if not state.bottles:
        state.bottles = backend.call("list_bottles") or []
    return state.bottles


def _resolve_bottle(token: str, backend: "Backend", state: State) -> dict:
    """name-or-path -> a bottle dict with at least {path, name}. an exact-case name
    match wins outright (so `Epic` and `epic` are each unambiguous on their own even
    if both bottles exist); only fall back to a case-insensitive match, then a
    literal path on disk, then a clear error."""
    bottles = _all_bottles(backend, state)
    exact_case = [b for b in bottles if b.get("name", "") == token]
    if len(exact_case) == 1:
        return exact_case[0]
    matches = exact_case or [b for b in bottles if b.get("name", "").lower() == token.lower()]
    if len(matches) == 1:
        return matches[0]
    if len(matches) > 1:
        lines = "\n".join(f"  {b.get('name')}  {b.get('path')}" for b in matches)
        raise BackendError(f"more than one bottle named {token!r}:\n{lines}\nuse the exact path instead")
    expanded = os.path.expanduser(token)
    if os.path.isdir(expanded):
        path = os.path.abspath(expanded)
        existing = next((b for b in bottles if b.get("path") == path), None)
        return existing or {"path": path, "name": token}
    names = ", ".join(b.get("name", "?") for b in bottles) or "none yet"
    raise BackendError(f"no bottle named {token!r} -- known bottles: {names}")


def _bottle_arg(ns, backend: "Backend", state: State) -> dict:
    """the bottle a command should use: the name/path given (positional or --bottle),
    else the one you `use`d in the shell, else a clear error."""
    token = getattr(ns, "bottle", None)
    if token:
        return _resolve_bottle(token, backend, state)
    if state.prefix:
        return {"path": state.prefix, "name": state.name}
    raise BackendError("no bottle selected -- pass a name, or in the shell run `use <n>` first")


def _games_in(backend: "Backend", prefix: str) -> list:
    return backend.call("scan_games", {"prefix": prefix}) or []


def _resolve_game(token: str, backend: "Backend", state: State, ns):
    """find a game by name: in --bottle if given, else across every bottle. an
    exact-case match wins outright, then a case-insensitive exact match, then a
    substring match -- each tier only kicks in if the one before found nothing.
    returns (game, bottle), or (None, None) if nothing matched (the caller falls
    back to treating the token as a raw exe path)."""
    explicit = getattr(ns, "bottle", None)
    bottles = [_resolve_bottle(explicit, backend, state)] if explicit else _all_bottles(backend, state)

    lower = token.lower()
    exact_case, exact_ci, sub = [], [], []
    for b in bottles:
        for g in _games_in(backend, b["path"]):
            name = g.get("name", "")
            if name == token:
                exact_case.append((g, b))
            elif name.lower() == lower:
                exact_ci.append((g, b))
            elif lower in name.lower():
                sub.append((g, b))

    hits = exact_case or exact_ci or sub
    if not hits:
        return None, None
    if len(hits) > 1:
        lines = "\n".join(f"  {g.get('name')}  (in {b.get('name')})" for g, b in hits)
        raise BackendError(f"more than one game matches {token!r}:\n{lines}\npass --bottle to narrow it down")
    return hits[0]


def _select(state: State, backend: "Backend", token: str) -> None:
    """`use N` or `use <name>` -- point the shell at a bottle."""
    if not state.bottles:
        state.bottles = backend.call("list_bottles") or []
    chosen = None
    if token.isdigit() and int(token) < len(state.bottles):
        chosen = state.bottles[int(token)]
    else:
        for b in state.bottles:
            if b.get("name", "").lower() == token.lower():
                chosen = b
                break
    if not chosen:
        print(_paint(f"No bottle {token!r} -- try `bottles` to see the numbered list.", _RED))
        return
    state.prefix, state.name = chosen.get("path"), chosen.get("name")
    print(f"Using {_paint(state.name or '?', _YEL)}  {_paint(state.prefix or '', _DIM)}")


def _show_bottles(data, state: State) -> None:
    """print bottles as a numbered list + remember it so `use N` can pick one."""
    state.bottles = data if isinstance(data, list) else []
    if not state.bottles:
        print(_paint("No bottles yet.", _DIM))
        return
    for i, b in enumerate(state.bottles):
        star = _paint("*", _GRN) if b.get("path") == state.prefix else " "
        name = _paint(b.get("name", "?"), _BOLD)
        be = _paint(b.get("default_backend", "auto"), _CYN)
        print(f" {star}[{i}] {name}  ({be})  {_paint(b.get('path', ''), _DIM)}")


def _coerce_value(raw: str):
    """cli text -> a python value for settings set: true/false and 1/0 -> bool
    (every known boolean bottle setting is genuinely a bool, not a number), then
    int, then float, else keep it as a plain string."""
    low = raw.lower()
    if low in ("true", "false"):
        return low == "true"
    if raw in ("1", "0"):
        return raw == "1"
    try:
        return int(raw)
    except ValueError:
        pass
    try:
        return float(raw)
    except ValueError:
        pass
    return raw


# ---- command handlers --------------------------------------------------------------
def _do_status(ns, backend: "Backend", state: State) -> None:
    status = backend.call("get_status")
    components = backend.call("get_components_status")
    running = backend.call("get_running_games") or []
    if ns.as_json:
        _emit({"status": status, "components": components, "running_count": len(running)}, True)
        return
    _print_kv([
        ("Wine found", "yes" if status.get("wine_found") else "no"),
        ("Wine path", status.get("wine_path") or ""),
        ("Wine version", components.get("wine_version") or ""),
        ("DXVK", "yes" if status.get("has_dxvk") else "no"),
        ("Mesa", "yes" if status.get("has_mesa") else "no"),
        ("Games running", str(len(running))),
    ])


def _do_bottles_list(ns, backend: "Backend", state: State) -> None:
    data = backend.call("list_bottles")
    if ns.as_json:
        _emit(data, True)
    else:
        _show_bottles(data, state)


def _do_bottles_create(ns, backend: "Backend", state: State) -> None:
    print(f"Creating bottle {ns.name}... (running wineboot, this can take a few seconds)")
    params = {"name": ns.name, "launcher_type": ns.launcher, "default_backend": ns.backend}
    if ns.path:
        params["path"] = ns.path
    if ns.steam_setup:
        params["steam_setup_path"] = ns.steam_setup
    result = backend.call("create_bottle", params)
    print(f"Created at {result.get('path')}.")
    if ns.launcher in ("steam", "epic"):
        print(f"{ns.launcher.capitalize()} setup continues in the background -- "
              f"check `status` or `bottles info {ns.name}` shortly.")


def _do_bottles_delete(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    if not ns.yes:
        if not sys.stdin.isatty():
            raise BackendError("refusing to delete without --yes in a non-interactive shell")
        prompt = f'This permanently deletes "{bottle.get("name")}" at {bottle["path"]}. Continue? [y/N] '
        if input(prompt).strip().lower() not in ("y", "yes"):
            print("Cancelled.")
            return
    backend.call("delete_bottle", {"path": bottle["path"]})
    print(f"Deleted {bottle.get('name')}.")


def _do_bottles_info(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    data = backend.call("get_bottle_config", {"path": bottle["path"]})
    if ns.as_json:
        _emit(data, True)
    else:
        _print_kv(sorted(data.items()))


def _do_bottles_move(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    result = backend.call("move_bottle", {"path": bottle["path"], "destination_parent": ns.destination})
    if result.get("unchanged"):
        print("Already there.")
    else:
        print(f"Moved to {result.get('path')}.")


def _do_bottles_init(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    backend.call("init_prefix", {"prefix": bottle["path"]})
    print("Done.")


def _do_bottles_clean(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    backend.call("clean_prefix", {"prefix": bottle["path"]})
    print("Done.")


def _do_bottles_kill(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    result = backend.call("kill_wineserver", {"prefix": bottle["path"]})
    killed, remaining = result.get("force_killed", 0), result.get("remaining", 0)
    print(f"Killed {killed} process(es).")
    if remaining:
        print(f"{remaining} still running -- try again, or check Activity Monitor.")


def _do_bottles_folder(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    backend.call("open_prefix_folder", {"prefix": bottle["path"]})
    print("Opened.")


def _do_bottles_winecfg(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    backend.call("open_winecfg", {"prefix": bottle["path"]})
    print("Opened.")


def _do_bottles_steam(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    params = {
        "prefix": bottle["path"], "backend": ns.backend, "silent": ns.silent,
        "wait_ready": ns.wait, "ready_cap_s": ns.wait_cap,
    }
    result = backend.call("launch_steam", params)
    if result.get("already_running"):
        print(f"Steam is already running (PID {result.get('pid')}).")
    else:
        print(f"Steam launched (PID {result.get('pid')}).")


def _do_engines_list(ns, backend: "Backend", state: State) -> None:
    scope = getattr(ns, "scope", None)
    if scope in ("installed", "uninstalled"):
        _do_engines_list_components(ns, backend, scope)
        return
    data = backend.call("list_backends")
    if ns.as_json:
        _emit(data, True)
        return
    auto = data.get("auto_resolved", "")
    rows = []
    for b in data.get("backends", []):
        label = b.get("label", "") + (" (default)" if b.get("id") == auto else "")
        rows.append((b.get("id", ""), label, "yes" if b.get("available") else "no"))
    _print_table(("id", "label", "available"), rows)


def _do_engines_list_components(ns, backend: "Backend", scope: str) -> None:
    """`engines list installed`/`engines list uninstalled` -- same COMPONENTS registry
    `install`/`uninstall`/`reinstall` use, filtered by current status."""
    status = backend.call("get_components_status") or {}
    update_info = backend.call("get_update_info") or {}
    want_installed = scope == "installed"
    matches = [c for c in COMPONENTS if bool(status.get(c["status_key"])) == want_installed]
    if ns.as_json:
        if want_installed:
            markers = _read_version_markers()
            data = [{
                "id": c["id"], "label": c["label"],
                "installed_version": markers.get(c["version_marker"]) if c["version_marker"] else None,
                "latest_version": update_info.get(c["latest_field"]) if c["latest_field"] else None,
                "update_available": bool(c["update_key"] and update_info.get(c["update_key"])),
            } for c in matches]
        else:
            data = [{"id": c["id"], "label": c["label"]} for c in matches]
        _emit(data, True)
        return
    if not matches:
        print(_paint(f"No components are {scope}.", _DIM))
        return
    if want_installed:
        markers = _read_version_markers()
        rows = []
        for c in matches:
            installed_version = markers.get(c["version_marker"], "?") if c["version_marker"] else "-"
            latest_version = update_info.get(c["latest_field"]) if c["latest_field"] else None
            update = "yes" if (c["update_key"] and update_info.get(c["update_key"])) else \
                     ("no" if c["update_key"] else "n/a")
            rows.append((c["label"], installed_version, latest_version or "-", update))
        _print_table(("component", "installed", "latest", "update available"), rows)
    else:
        for c in matches:
            print(c["label"])


def _do_engines_status(ns, backend: "Backend", state: State) -> None:
    components = backend.call("get_components_status")
    wine = backend.call("detect_wine") or {}
    if ns.as_json:
        _emit({"components": components, "wine": wine}, True)
        return
    print(_paint("Components:", _BOLD))
    _print_kv(sorted(components.items()))
    print()
    print(_paint("Wine builds:", _BOLD))
    rows = [(w.get("id", ""), "yes" if w.get("installed") else "no", w.get("version") or "", w.get("path") or "")
            for w in wine.get("variants", [])]
    _print_table(("id", "installed", "version", "path"), rows)


# ---- engines: component install/uninstall/reinstall ------------------------------
# Mirrors SetupSettingsTab's component list in Sources/SettingsSheet.swift -- keep
# these two in sync if a component is ever added/removed there.
# version_marker: key in the .mnc_versions marker file (see _read_version_markers) that
# holds the installed tag, or None if this component doesn't record one. latest_field:
# the get_update_info field with the latest available tag/name, or None if the backend
# doesn't track updates for it (wine_devel/vr write a marker but nothing compares it;
# wine_unified/dxvk/vkd3d/gptk_dlls don't even write one -- installer.sh never calls
# write_component_version for those).
COMPONENTS = [
    {"id": "tools", "label": "Tools (git, 7z, wget)",
     "install": "install_tools", "uninstall": "uninstall_tools",
     "status_key": "has_tools", "update_key": "tools_update_available",
     "version_marker": "tools", "latest_field": "cheese_latest_tag",
     "aliases": ["tools", "tool"]},
    {"id": "wine_stable", "label": "Wine (Stable)",
     "install": "install_wine", "uninstall": "uninstall_wine",
     "status_key": "has_wine_stable", "update_key": "wine_stable_update_available",
     "version_marker": "wine_stable", "latest_field": "cheese_latest_tag",
     "aliases": ["wine stable", "stable"]},
