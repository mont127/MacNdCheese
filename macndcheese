def _game_config_overlay(backend: "Backend", bottle: dict, game: dict, ns) -> dict:
    """replicates Sources/MacNCheeseURLHandler.swift's launch dispatch: a stored
    per-game override wins over the default, and an explicit cli flag wins over that."""
    cfg = backend.call("get_game_config", {"prefix": bottle["path"], "appid": game.get("appid", "")}) or {}
    msync = cfg.get("msync", True)
    return {
        "backend": ns.backend or cfg.get("backend", "auto"),
        "esync": False if msync else cfg.get("esync", True),
        "msync": msync,
        "retina_mode": cfg.get("retina_mode", False),
        "metal_hud": cfg.get("metal_hud", False),
        "custom_env": cfg.get("custom_env", ""),
        "args": ns.args or cfg.get("args", ""),
        "exe": cfg.get("exe") or game.get("exe"),
    }


def _do_launch(ns, backend: "Backend", state: State) -> None:
    target = ns.target
    game, bottle = _resolve_game(target, backend, state, ns)

    if game is not None:
        overlay = _game_config_overlay(backend, bottle, game, ns)
        name = game.get("name", target)
        if game.get("epic_app_name"):
            kind = "epic"
            result = backend.call("legendary_launch_game", {
                "app_name": game["epic_app_name"], "prefix": bottle["path"],
                "backend": overlay["backend"], "retina_mode": overlay["retina_mode"],
                "metal_hud": overlay["metal_hud"], "esync": overlay["esync"], "msync": overlay["msync"],
                "custom_env": overlay["custom_env"], "game_name": name,
            })
        else:
            kind = "game"
            exe = overlay["exe"]
            if not exe:
                raise BackendError(f"{name} has no known executable -- check `list games`")
            result = backend.call("launch_game", {
                "prefix": bottle["path"], "exe": exe, "args": overlay["args"], "backend": overlay["backend"],
                "install_dir": game.get("install_dir", ""), "retina_mode": overlay["retina_mode"],
                "metal_hud": overlay["metal_hud"], "esync": overlay["esync"], "msync": overlay["msync"],
                "steam_appid": game.get("appid", ""), "game_name": name, "steam_mode": "silent",
            })
    else:
        path = os.path.expanduser(target)
        if not (os.path.isfile(path) or target.lower().endswith((".exe", ".msi"))):
            raise BackendError(f"no game named {target!r}, and {target!r} is not an existing exe path")
        kind = "exe"
        bottle = _bottle_arg(ns, backend, state)
        name = os.path.basename(path)
        result = backend.call("run_exe", {"prefix": bottle["path"], "exe": path, "args": ns.args or ""})

    if result.get("already_running"):
        print(f"{name} is already running (PID {result.get('pid')}).")
        return

    tail = f", backend {result['backend']}" if result.get("backend") else ""
    print(f"Launched {name} (PID {result.get('pid')}{tail}).")

    if kind in ("game", "epic") and result.get("pid"):
        # the backend clears discord presence / game mode / dll patches for this
        # pid from a thread that needs the backend process to stay alive -- see
        # State.keep_alive_pids and _detach_and_wait.
        state.keep_alive_pids.add(result["pid"])

    log_path = result.get("log_path")
    if kind == "exe":
        # run_exe never returns a log_path, and there's nothing useful to stream
        # for an arbitrary installer/utility -- say so and stop, --logs or not.
        if ns.logs:
            print(f"No log is exposed for a raw exe launch -- check {GENERAL_LOG_PATH} if something looks wrong.")
        return

    if not ns.logs:
        if log_path:
            print(f"Run again with --logs to stream {log_path}")
        return

    if not log_path:
        print("No per-game log for Epic launches -- streaming the general backend log instead.")
        log_path = GENERAL_LOG_PATH
    _tail_log(log_path, result.get("pid"))


def _do_install_exe(ns, backend: "Backend", state: State) -> None:
    """`mnc install <exe>` -- run a windows installer .exe/.msi inside a bottle.
    Mirrors `mnc uninstall <exe>`; unlike `engines install`, --bottle actually
    matters here since run_exe launches the installer inside that specific
    prefix. Reuses the same run_exe path `launch <exe-not-a-known-game>` falls
    back to, but as its own command (discoverable, and streams the installer's
    log properly instead of declining like launch's raw-exe fallback does)."""
    bottle = _bottle_arg(ns, backend, state)
    path = os.path.expanduser(ns.exe)
    if not os.path.isfile(path):
        raise BackendError(f"no such file: {path!r}")
    result = backend.call("run_exe", {"prefix": bottle["path"], "exe": path, "args": ns.args or ""})
    name = os.path.basename(path)
    if result.get("already_running"):
        print(f"{name} is already running (PID {result.get('pid')}).")
        return
    log_path = os.path.join(bottle["path"], "mnc-installer.log")
    print(f"Started {name} (PID {result.get('pid')}).")
    if ns.logs:
        _tail_log(log_path, result.get("pid"))
    else:
        print(f"Run again with --logs to stream {log_path}")


