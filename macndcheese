def _normalize_component(s: str) -> str:
    return " ".join(s.lower().replace("-", " ").split())


def _resolve_component(token: str) -> dict:
    """name -> a COMPONENTS entry. an exact alias match wins outright (so "stable",
    "staging", "devel", "unified" are each unambiguous shorthand on their own even
    though they're also substrings of another component's alias); only a genuinely
    ambiguous bare root like "wine" falls through to listing every component whose
    alias contains it, so the caller finds out which one to be specific about."""
    norm = _normalize_component(token)
    exact = [c for c in COMPONENTS if norm in {_normalize_component(a) for a in c["aliases"]}]
    if len(exact) == 1:
        return exact[0]
    partial = [c for c in COMPONENTS
               if any(norm in _normalize_component(a) or _normalize_component(a) in norm
                      for a in c["aliases"])]
    if len(partial) == 1:
        return partial[0]
    if len(partial) > 1:
        names = ", ".join(f'"{c["aliases"][0]}"' for c in partial)
        raise BackendError(f"{token!r} is ambiguous -- which one do you mean: {names}?")
    known = ", ".join(sorted({c["aliases"][0] for c in COMPONENTS}))
    raise BackendError(f"no component named {token!r} -- known components: {known}")


def _resolve_components(tokens: "list[str]") -> "list[dict]":
    seen_ids: set = set()
    out = []
    for token in tokens:
        c = _resolve_component(token)
        if c["id"] not in seen_ids:
            seen_ids.add(c["id"])
            out.append(c)
    return out


APP_BUNDLE_ID = "com.marcel.macncheese"


def _defaults_read(key: str, default: str) -> str:
    """read a value the Swift app stored via @AppStorage -- same domain, same key,
    so the cli installs to whatever custom paths the user set in Settings -> Paths."""
    try:
        result = subprocess.run(["defaults", "read", APP_BUNDLE_ID, key],
                                 capture_output=True, text=True, timeout=3)
    except Exception:
        return default
    value = result.stdout.strip()
    return value if result.returncode == 0 and value else default


