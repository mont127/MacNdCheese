    print(f"\n{len(rows)} verb(s).")


def _do_winetricks_installed(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    data = backend.call("winetricks_list_installed", {"prefix": bottle["path"]})
    installed = data.get("installed", [])
    if ns.as_json:
        _emit(installed, True)
        return
    if not installed:
        print(_paint("Nothing installed via winetricks yet.", _DIM))
        return
    for verb in installed:
        print(f"  {verb}")
    print(f"\n{len(installed)} verb(s) installed.")


def _do_winetricks_install(ns, backend: "Backend", state: State) -> None:
    bottle = _bottle_arg(ns, backend, state)
    result = backend.call("winetricks_run", {
        "prefix": bottle["path"], "verbs": ns.verbs, "force": ns.force,
    })
    job_id = result.get("job_id")
    label = bottle.get("name") or bottle["path"]
    print(f"Installing {', '.join(ns.verbs)} into {label} -- control-c to cancel:")
    offset = 0
    try:
        while True:
            time.sleep(0.5)
            progress = backend.call("get_install_progress", {"job_id": job_id, "offset": offset})
            for line in progress.get("lines", []):
                print(f"  {line}")
            offset = progress.get("total_lines", offset)
            if progress.get("done"):
                if progress.get("failed"):
                    sys.exit(_paint("Finished with errors.", _RED))
                print(_paint("Done.", _GRN))
                return
    except KeyboardInterrupt:
        # the job only exists in THIS backend process's memory -- if we just
        # exit, main()'s finally block closes the backend, its daemon thread
        # dies mid-verb, and the underlying wine/winetricks subprocess (its
        # own session, so it survives that) is orphaned with no way left to
        # check on or cancel it. cancel explicitly instead of detaching, so
        # control-c means what people expect it to mean: stop.
        backend.call("winetricks_cancel", {"job_id": job_id})
        print()
        print("Cancelled.")


def _do_winetricks_cancel(ns, backend: "Backend", state: State) -> None:
    backend.call("winetricks_cancel", {"job_id": ns.job_id})
    print("Cancelled.")


def _do_setup(ns, backend: "Backend", state: State) -> None:
    target = os.path.realpath(os.path.join(HERE, "macndcheese"))
    print(f"Linking {PATH_BIN_DIR}/macndcheese and {PATH_BIN_DIR}/mnc to {target}")
    try:
        os.makedirs(PATH_BIN_DIR, exist_ok=True)
        for link_name in ("macndcheese", "mnc"):
            link_path = os.path.join(PATH_BIN_DIR, link_name)
            if os.path.islink(link_path) or os.path.exists(link_path):
                os.remove(link_path)
            os.symlink(target, link_path)
        print("Done. Open a new terminal window so your shell picks it up.")
    except PermissionError:
        print(f"{PATH_BIN_DIR} isn't writable. Run this instead:")
        print(f"  sudo ln -sf {shlex.quote(target)} {PATH_BIN_DIR}/macndcheese")
        print(f"  sudo ln -sf {shlex.quote(target)} {PATH_BIN_DIR}/mnc")


def _do_commands(ns, backend: "Backend", state: State) -> None:
    cmds = _known_cmds()
    print(f"{len(cmds)} backend commands -- reach any with `raw <name> key=value ..`\n")
    print("  " + "\n  ".join(cmds))


def _do_raw(ns, backend: "Backend", state: State) -> None:
    _emit(backend.call(ns.cmd, _parse_kv(ns.kv)), ns.as_json)


