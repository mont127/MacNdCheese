MESA_URL = "https://github.com/pal1000/mesa-dist-win/releases/download/23.1.9/mesa3d-23.1.9-release-msvc.7z"

VERSION_MARKER_PATH = os.path.expanduser(
    "~/Library/Application Support/MacNCheese/deps/.mnc_versions")


def _read_version_markers() -> dict:
    """same file + format as backend_server.py's VERSION_MARKER/_read_version_marker --
    read directly since there's no backend command that returns raw installed tags."""
    try:
        with open(VERSION_MARKER_PATH, "r", encoding="utf-8", errors="ignore") as f:
            lines = f.read().splitlines()
    except OSError:
        return {}
    out = {}
    for line in lines:
        if "=" in line:
            key, _, value = line.partition("=")
            out[key.strip()] = value.strip()
    return out


def _installer_script_path() -> "str | None":
    candidates = [os.path.join(HERE, "installer.sh"), os.path.expanduser("~/macndcheese/installer.sh")]
    return next((p for p in candidates if os.path.exists(p)), None)


# installer.sh's install_*/uninstall_* actions for every one of these components
# install to shared, machine-wide locations (PORTABLE_DIR / $HOME/...) -- grepping
# the whole script confirms $PREFIX_DIR/$WINEPREFIX is only ever read by init_prefix
# (bottle creation) and two unrelated openxr-registration actions, never by any
# action in COMPONENTS above. So there's genuinely no bottle to scope these to;
# a fixed placeholder is all `run_installer` needs.
_INSTALLER_PLACEHOLDER_PREFIX = os.path.expanduser("~/wined")


def _run_installer_job(backend: "Backend", actions: "list[str]") -> None:
    if not actions:
        print(_paint("Nothing to do.", _DIM))
        return
    installer_path = _installer_script_path()
    if not installer_path:
        raise BackendError("installer.sh not found -- looked next to the cli and in ~/macndcheese/installer.sh")
    paths = _installer_paths()
    job = backend.call("run_installer", {
        "installer_path": installer_path,
        "actions": actions,
        "prefix": _INSTALLER_PLACEHOLDER_PREFIX,
        "dxvk_src": paths["dxvk_src"],
        "dxvk64": paths["dxvk64"],
        "dxvk32": paths["dxvk32"],
        "mesa": paths["mesa"],
        "mesa_url": MESA_URL,
        "dxmt": paths["dxmt"],
        "vkd3d": paths["vkd3d"],
        "gptk_dir": paths["gptk_dir"],
    }) or {}
    job_id = job.get("job_id")
    offset = 0
    failed = False
    while True:
        time.sleep(0.5)
        progress = backend.call("get_install_progress", {"job_id": job_id, "offset": offset}) or {}
        for line in progress.get("lines", []):
            print(line)
        offset = progress.get("total_lines", offset)
        if progress.get("done"):
            failed = progress.get("failed", False)
            break
    if failed:
        raise BackendError("one or more actions failed -- see the log above")
    print(_paint("Done.", _GRN))


def _is_wildcard(names: "list[str]") -> bool:
    return len(names) == 1 and names[0].lower() in ("*", "all")


def _expand_or_resolve(names: "list[str]", status: dict, only_installed: bool) -> "list[dict]":
    """"*"/"all" expands to every component (or, when only_installed, just the ones
    currently installed); any other input goes through the normal name resolver so
    ambiguous/unknown names still get a clear error."""
    if _is_wildcard(names):
        if only_installed:
            return [c for c in COMPONENTS if status.get(c["status_key"])]
        return list(COMPONENTS)
    return _resolve_components(names)


def _print_dry_run(pairs: "list[tuple[str, str]]") -> None:
    if not pairs:
        print(_paint("Nothing to do.", _DIM))
        return
    print("Would run:")
    for label, action in pairs:
        print(f"  {action}  ({label})")


def _confirm_wildcard(verb: str, labels: "list[str]", yes: bool) -> bool:
    """"*"/"all" is exactly what let an earlier `engines install all` silently try to
    install 4 real components on a live machine -- require --yes (or an interactive
    y/N) before a wildcard actually touches more than one thing."""
    if yes or not labels:
        return True
    names = ", ".join(labels)
    if not sys.stdin.isatty():
        raise BackendError(f"refusing to {verb} {len(labels)} component(s) without --yes "
                            f"in a non-interactive shell: {names}")
    if input(f"This will {verb} {len(labels)} component(s): {names}. Continue? [y/N] "
             ).strip().lower() not in ("y", "yes"):
        print("Cancelled.")
        return False
    return True


def _do_engines_install(ns, backend: "Backend", state: State) -> None:
    status = backend.call("get_components_status") or {}
    update_info = backend.call("get_update_info") or {}
    components = _expand_or_resolve(ns.names, status, only_installed=False)
    to_install = []
    for c in components:
        installed = bool(status.get(c["status_key"]))
        has_update = bool(update_info.get(c["update_key"])) if c["update_key"] else False
        if not installed or has_update:
            to_install.append(c)
        else:
            print(f"{c['label']} is already installed (up to date) -- skipping. "
                  f"Use `engines reinstall` to force.")
    if ns.dry_run:
        _print_dry_run([(c["label"], c["install"]) for c in to_install])
        return
    if _is_wildcard(ns.names) and not _confirm_wildcard("install", [c["label"] for c in to_install], ns.yes):
        return
    _run_installer_job(backend, [c["install"] for c in to_install])


def _do_engines_reinstall(ns, backend: "Backend", state: State) -> None:
    status = backend.call("get_components_status") or {}
    components = _expand_or_resolve(ns.names, status, only_installed=True)
    if _is_wildcard(ns.names) and not components:
        print(_paint("Nothing is installed yet -- nothing to reinstall.", _DIM))
        return
    if ns.dry_run:
        _print_dry_run([(c["label"], c["install"]) for c in components])
        return
    if _is_wildcard(ns.names) and not _confirm_wildcard("reinstall", [c["label"] for c in components], ns.yes):
        return
    _run_installer_job(backend, [c["install"] for c in components])


def _do_engines_uninstall(ns, backend: "Backend", state: State) -> None:
    status = backend.call("get_components_status") or {}
    components = _expand_or_resolve(ns.names, status, only_installed=True)
    if _is_wildcard(ns.names) and not components:
        print(_paint("Nothing is installed -- nothing to uninstall.", _DIM))
        return
    to_uninstall = []
    for c in components:
        if status.get(c["status_key"]):
            to_uninstall.append(c)
        else:
            print(f"{c['label']} isn't installed -- nothing to do.")
    if ns.dry_run:
        _print_dry_run([(c["label"], c["uninstall"]) for c in to_uninstall])
        return
    if _is_wildcard(ns.names) and not _confirm_wildcard("uninstall", [c["label"] for c in to_uninstall], ns.yes):
        return
    _run_installer_job(backend, [c["uninstall"] for c in to_uninstall])


